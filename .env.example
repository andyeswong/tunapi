# Required: strong shared secret for /register, /list, /register DELETE
TUNAPI_SECRET=replace-with-a-long-random-secret

# Public-facing domain used to build returned URLs (no protocol)
TUNAPI_BASE_DOMAIN=example.com

# URL scheme used in the register response URL
TUNAPI_PUBLIC_SCHEME=https

# Listen port for TunAPI service
TUNAPI_PORT=8443

# File where routes are persisted
TUNAPI_ROUTES_FILE=/etc/tunapi/routes.json

# Comma-separated allowlist for route targets
# Keep this as strict as possible.
TUNAPI_ALLOWED_TARGETS=127.0.0.1,localhost
